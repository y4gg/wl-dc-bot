{
  "name": "wl-dc-bot",
  "version": "1.0.0",
  "description": "Discord ticket bot with tags, transcripts, and auto-close functionality",
  "scripts": {
    "start": "bun run dist/index.js",
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "register-commands": "bun run src/utils/registerCommands.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "keywords": ["discord", "ticket", "bot"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
